    },
    {
      "page": "/api/auth/logout",
      "regex": "^/api/auth/logout(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/logout(?:/)?$"
    },
    {
      "page": "/api/auth/password",
      "regex": "^/api/auth/password(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/password(?:/)?$"
    },
    {
      "page": "/api/auth/token",
      "regex": "^/api/auth/token(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/token(?:/)?$"
    },
    {
      "page": "/api/backup",
      "regex": "^/api/backup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/backup(?:/)?$"
    },
    {
      "page": "/api/export",
      "regex": "^/api/export(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/export(?:/)?$"
    },
    {
      "page": "/api/mcp",
      "regex": "^/api/mcp(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/mcp(?:/)?$"
    },
    {
      "page": "/api/readings",
      "regex": "^/api/readings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/readings(?:/)?$"
    },
    {
      "page": "/api/readings/recalculate",
      "regex": "^/api/readings/recalculate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/readings/recalculate(?:/)?$"
    },
    {
      "page": "/api/settings",
      "regex": "^/api/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/settings(?:/)?$"
    },
    {
      "page": "/api/stats",
      "regex": "^/api/stats(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/stats(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/mcp",
